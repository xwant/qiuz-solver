{
  "manifest_version": 3,
  "name": "Quiz Solver - Gemini",
  "version": "2.0",
  "description": "Автоматически решает тесты по мехатронике. Работает на бесплатном Gemini API.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    { "matches": ["<all_urls>"], "js": ["content.js"], "run_at": "document_idle" }
  ],
  "background": { "service_worker": "background.js" }
}
